{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "index.ts",
    "client.ts",
    "service.ts",
    "types.ts",
    "errors.ts",
    "mappers.ts"
  ],
  "exclude": ["dist", "node_modules", "_spec", "_ref"]
}
